# Copy to infra/cloudflare/.dev.vars for local experiments.
# Do not commit real values. Manage secrets in Cloudflare instead.

PULSEFM_ENV=development
PULSEFM_REGION=global
VOTE_OPTIONS=energetic,dark,uplifting,cinematic,ambient,driving
OPTIONS_PER_WINDOW=4
VOTE_CLOSE_LEAD_SECONDS=60
STUBBED_DURATION_MS=300000
STARTUP_NEXT_SONG_DELAY_SECONDS=5
